{
   "manifest_version": 3,
   "name": "Threads Filter",
   "version": "0.0.2",
   "description": "Improve your Threads experience with an affect filter.",
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
   },
   "action": {
      "default_popup": "menu/options.html"
   },
   "content_scripts": [ {
      "matches": [ "*://*.threads.com/*", "*://*.threads.net/*", "*://mil.psy.ntu.edu.tw/*" ],
      "run_at": "document_start",
      "js": [ "libs/browser-polyfill.min.js", "libs/jquery.min.js", "config.js", "libs/client.js", "libs/utils.js", "libs/timeme.min.js", "events.js", "logic.js", "launcher.js" ],
      "css": [ "static/style.css" ]
   } ],
   "web_accessible_resources": [ {
      "matches": [ "*://*.threads.com/*", "*://*.threads.net/*","*://mil.psy.ntu.edu.tw/*" ],
      "resources": [ "injected.js" ]
   } ],
   "background": {
      "service_worker": "service_worker.js",
      "type": "module"
   },
   "permissions": [ "storage", "alarms" ],
   "host_permissions": [ "https://mil.psy.ntu.edu.tw/*" ],
   "browser_specific_settings": {
      "safari": {
         "strict_min_version": "16.4"
      }
   }
}

